# Образец. СКОПИРУЙ (не переименовывай) в .env.local и подставь значения.
# Сам .env.local в git не попадает — этот файл нужен, чтобы было видно,
# какие переменные нужны проекту, без самих значений.
#
# Где взять: Supabase -> Settings -> API Keys.
#   URL  — поле "Project URL", БЕЗ хвоста /rest/v1/
#   KEY  — публичный ключ: "anon" / "public" / "publishable" (sb_publishable_...).
#          НЕ service_role / secret — тот обходит RLS и в NEXT_PUBLIC_ ему нельзя.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Только сервер. БЕЗ префикса NEXT_PUBLIC_ — это не формальность:
# Next.js подставляет в браузерный бандл только переменные с этим
# префиксом, поэтому без него ключ физически не может уехать на клиент.

# service_role: обходит RLS, может всё. Нужен, чтобы писать просмотры в
# закрытую таблицу page_views. Supabase -> Settings -> API Keys -> Reveal.
SUPABASE_SERVICE_ROLE_KEY=

# Случайная строка. Ею солится хэш IP посетителя (сам IP не хранится).
# Сгенерировать свою: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VIEW_HASH_SALT=

# --- Stripe (Этап 4, подэтап B). Оба ключа — только сервер.
# Секретный ключ API: Stripe Dashboard -> Developers -> API keys.
# В разработке — тестовый (sk_test_...), на проде — живой (sk_live_...).
STRIPE_SECRET_KEY=

# Секрет подписи вебхука. Локально выдаёт `stripe listen`, на проде —
# Dashboard -> Developers -> Webhooks -> эндпоинт -> Signing secret.
# Без него вебхук отвечает 500 и заказы не записываются.
STRIPE_WEBHOOK_SECRET=

# --- Отдельная база под превью/локалку (см. CLAUDE.md п.11). Эти три
# переменные НЕ читает код напрямую — они подставляются в основные три
# на Vercel Preview (и руками в локальной разработке при обкатке миграций).
NEXT_PUBLIC_SUPABASE_URL_PREVIEW=
NEXT_PUBLIC_SUPABASE_ANON_KEY_PREVIEW=
SUPABASE_SERVICE_ROLE_KEY_PREVIEW=
